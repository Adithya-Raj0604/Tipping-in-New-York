import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
from sklearn.preprocessing import MinMaxScaler

# Set plot style
sns.set(style="whitegrid")

# Load preprocessed dataset (you can replace this with your actual path)
df = pd.read_parquet("sampled_taxi_weather_data.parquet")

# Rename columns for consistency (if not done already)
df.rename(columns={
    'temperature_2m (°C)': 'temperature',
    'cloudcover_low (%)': 'cloudcover_low',
    'cloudcover_mid (%)': 'cloudcover_mid',
    'cloudcover_high (%)': 'cloudcover_high',
    'windspeed_10m (km/h)': 'windspeed',
    'winddirection_10m (°)': 'winddirection',
}, inplace=True)

# Map license type to service names
service_mapping = {
    'HV0002': 'juno',
    'HV0003': 'uber',
    'HV0004': 'via',
    'HV0005': 'lyft'
}
df['service_name'] = df['hvfhs_license_num'].map(service_mapping)

# One-hot encode service types
one_hot_encoding = pd.get_dummies(df['service_name'], prefix='is')
df = pd.concat([df, one_hot_encoding], axis=1)

# Calculate tip percentage
df = df[df['base_passenger_fare'] > 0]
df['tip_percent'] = df['tips'] / (df['base_passenger_fare'] + df['tolls'] + df['sales_tax'])

# Define ride-sharing flags
df['shared_with_friend'] = (df['shared_request_flag'] == "Y") & (df['shared_match_flag'] == "N")
df['shared_with_stranger'] = df['shared_match_flag'] == "Y"
df['ride_type'] = df['shared_with_stranger'].replace({True: 'Shared', False: 'Non-Shared'})


# 1. Histogram of Tip Percentage
plt.figure(figsize=(8, 5))
sns.histplot(df['tip_percent'], bins=50, kde=True)
plt.title("Distribution of Tip Percentage")
plt.xlabel("Tip Percent")
plt.ylabel("Frequency")
plt.tight_layout()
plt.show()

# 2. Boxplot: Tip Percent by Service Provider
df['Service'] = df[['is_uber', 'is_lyft', 'is_juno', 'is_via']].idxmax(axis=1).str.replace('is_', '')

plt.figure(figsize=(8, 5))
sns.boxplot(data=df, x='Service', y='tip_percent')
plt.title("Tip Percentage by Service Provider")
plt.xlabel("Service Provider")
plt.ylabel("Tip Percent")
plt.tight_layout()
plt.show()

# 3. Boxplot: Shared vs Non-Shared
plt.figure(figsize=(6, 5))
sns.boxplot(data=df, x='ride_type', y='tip_percent')
plt.title("Tip Percentage: Shared vs. Non-Shared Rides")
plt.xlabel("Ride Type")
plt.ylabel("Tip Percent")
plt.tight_layout()
plt.show()

print(df.columns.tolist())

# 4. Scatter Plot: Precipitation vs Tip Percentage
plt.figure(figsize=(8, 5))
sns.scatterplot(data=df, x='precipitation (mm)', y='tip_percent', alpha=0.5)
plt.title("Tip Percentage vs. Precipitation")
plt.xlabel("Precipitation (mm)")
plt.ylabel("Tip Percent")
plt.tight_layout()
plt.show()
